Terminals unused in grammar

    GOTOSYM
    NEG


Grammar

    0 $accept: program $end

    1 program: constdeclarations rules

    2 constdeclarations: ε

    3 $@1: ε

    4 constdeclarations: constdeclarations CONSTSYM UNDEFIDENTSYM ASSIGNSYM $@1 expr ';'
    5                  | constdeclarations CONSTSYM error ';'
    6                  | constdeclarations CONSTSYM error CONSTSYM

    7 rules: category
    8      | rule
    9      | rules category
   10      | rules rule

   11 category: CATEGORYSYM UNDEFIDENTSYM '{' INFOSYM '(' STRINGSYM ')' LINKSYM '(' STRINGSYM STRINGSYM ')' '}'

   12 rule: maybename '{' altrules '}'

   13 @2: ε

   14 $@3: ε

   15 rule: maybename '{' '{' gbglhslist @2 '~' gbglhslist ARROWSYM INFOSYM '(' $@3 info '}' '}'

   16 @4: ε

   17 rule: maybename '{' '/' STRINGSYM '/' ARROWSYM @4 rhslist '}'
   18     | maybename '{' '/' error '}'
   19     | maybename '{' error '}'

   20 newscope: ε

   21 maybename: ε
   22          | UNDEFIDENTSYM ':' maybename
   23          | LABELIDENTSYM ':' maybename
   24          | UNDEFIDENTSYMAT
   25          | RULEIDENTSYMAT
   26          | '@'

   27 altrules: altrule
   28         | altrules ';' newscope altrule

   29 $@5: ε

   30 altrules: error ';' $@5 altrule

   31 @6: ε

   32 altrule: lhs ARROWSYM @6 rhslist

   33 @7: ε

   34 altrule: error ARROWSYM @7 rhslist

   35 rhslist: ε
   36        | rhslist rhs

   37 rhs: MARKSYM '(' setmark mark
   38    | CORRSYM '(' setcorr corr
   39    | JUMPSYM '(' setjump jump
   40    | INFOSYM '(' setinfo info
   41    | ACTIONSYM '(' setaction action
   42    | DETECTSYM '(' STRINGSYM ')'
   43    | ACCEPTSYM '(' STRINGSYM ')'
   44    | LINKSYM '(' STRINGSYM STRINGSYM ')'
   45    | error ')'

   46 setmark: ε

   47 setcorr: ε

   48 setjump: ε

   49 setinfo: ε

   50 setaction: ε

   51 gbglhslist: lhs
   52           | gbglhslist ';' lhs

   53 lhs: elements

   54 elements: element
   55         | elements ',' element

   56 $@8: ε

   57 elements: elements elementname $@8 maybeexpr ')'
   58         | error ','

   59 $@9: ε

   60 $@10: ε

   61 element: elementname $@9 maybeexpr ')' $@10 maybeocc

   62 $@11: ε

   63 element: elementname error ')' $@11 maybeocc
   64        | ENDLEFTCONTEXTSYM
   65        | BEGINRIGHTCONTEXTSYM

   66 elementname: UNDEFIDENTSYM '('
   67            | '(' helprule ')' '('
   68            | '(' error ')' '('
   69            | error '('

   70 helprule: UNDEFIDENTSYM
   71         | RULEIDENTSYM
   72         | RULEIDENTSYMAT
   73         | UNDEFIDENTSYM '/' UNDEFIDENTSYM
   74         | RULEIDENTSYM '/' UNDEFIDENTSYM
   75         | RULEIDENTSYMAT '/' UNDEFIDENTSYM

   76 maybeocc: ε
   77         | INTEGERSYM
   78         | '*'
   79         | '+'
   80         | '?'

   81 mark: exprseq ')'
   82     | error ')'

   83 corr: ')'
   84     | exprseq ')'
   85     | error ')'

   86 jump: ')'
   87     | UNDEFIDENTSYM ')'
   88     | LABELIDENTSYM ')'
   89     | UNDEFIDENTSYM ',' expr ')'
   90     | LABELIDENTSYM ',' expr ')'
   91     | error ')'

   92 info: ')'
   93     | exprseq ')'
   94     | error ')'

   95 action: ')'
   96       | actionident ')'
   97       | actionident ',' args ')'
   98       | error ')'

   99 actionident: TAGIDENTSYM
  100            | CHECKIDENTSYM
  101            | LOOKUPIDENTSYM
  102            | EDITIDENTSYM
  103            | HELPIDENTSYM
  104            | ACCEPTIDENTSYM

  105 maybeexpr: ε
  106          | expr

  107 expr: REALSYM
  108     | INTEGERSYM
  109     | STRINGSYM
  110     | VARIDENTSYM
  111     | RULEELEMENTIDENTSYM
  112     | methodorattribute
  113     | FUNCIDENTSYM arglist
  114     | CONSTIDENTSYM
  115     | UNDEFIDENTSYM
  116     | expr '.' methodorattribute
  117     | expr '.' error
  118     | expr '+' expr
  119     | expr '-' expr
  120     | expr '=' expr
  121     | expr '~' expr
  122     | expr NESYM expr
  123     | expr LESYM expr
  124     | expr GESYM expr
  125     | expr '<' expr
  126     | expr '>' expr
  127     | expr '&' expr
  128     | expr '|' expr
  129     | expr ASSIGNSYM expr
  130     | '!' expr
  131     | '(' '-' expr ')'
  132     | '(' expr ')'
  133     | expr '[' expr ']'
  134     | PROBSYM '(' expr ',' expr ')'
  135     | FORALLSYM '(' expr ')'
  136     | EXISTSYM '(' expr ')'

  137 $@12: ε

  138 expr: IFSYM expr THENSYM $@12 exprseq ELSESYM exprseq ENDSYM
  139     | IFSYM error ENDSYM

  140 methodorattribute: ATTRIDENTSYM
  141                  | METHIDENTSYM arglist

  142 arglist: '(' args ')'
  143        | '(' ')'
  144        | error ')'

  145 args: expr
  146     | expr ',' args

  147 exprseq: expr
  148        | expr exprseq


